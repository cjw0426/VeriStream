%% VeriStream 感知-推理解耦方法图源文件
flowchart LR
    V[视频 V] --> C[因果切片器\n只保留 t <= t_q]
    C --> P[感知角色\n冻结 Qwen3-VL\n粗粒度观察]
    P --> L0[L0 原始证据\n视频/chunk/时间指针]
    P --> L1[L1 观察记忆\n对象·动作·状态·置信度]
    L1 --> L2[L2 事件记忆\n时间邻近与实体聚合]
    Q[问题 q] --> R[推理角色\n冻结 Qwen3-VL\nJSON 控制器]
    L1 --> R
    L2 --> R
    R --> T{工具调用}
    T --> S[search_memory\n混合检索]
    T --> I[inspect_segment\n局部重观察]
    T --> Y[verify_evidence\n原始帧核验]
    T --> X[compare_segments\n状态比较]
    I --> P
    Y --> P
    P --> L1
    S --> R
    Y --> R
    X --> R
    R --> A[已核验证据 + 问题\n最终答案]
    classDef input fill:#eef2f7,stroke:#4a5568,color:#1a202c;
    classDef perception fill:#e6f4f1,stroke:#2a9d8f,color:#173f3a;
    classDef memory fill:#fff4dc,stroke:#d4a252,color:#553b12;
    classDef reasoning fill:#eaf0fb,stroke:#4a90d9,color:#18324f;
    classDef tool fill:#f8e9e7,stroke:#d55e00,color:#5a2416;
    class V,C,Q,A input;
    class P,L0,L1,L2 perception;
    class R reasoning;
    class T,S,I,Y,X tool;
